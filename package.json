{
  "name": "kairos",
  "version": "0.1.0",
  "description": "Kairos — the open-source CreatorOS agent harness. Runs your entire social presence: posting at scale, automations, comment & DM replies, analytics.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "kai": "bin/kai.mjs"
  },
  "scripts": {
    "prestart": "node scripts/ensure-deps.mjs",
    "start": "tsx src/index.ts",
    "predashboard": "node scripts/ensure-deps.mjs",
    "dashboard": "tsx dashboard/server.ts",
    "preworker": "node scripts/ensure-deps.mjs",
    "worker": "tsx src/worker/index.ts",
    "pretest": "node scripts/ensure-deps.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "creatoros",
    "kairos",
    "social-media",
    "ai-agent",
    "agent-harness",
    "automation",
    "claude"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kevinbadi/kairos"
  },
  "bugs": {
    "url": "https://github.com/kevinbadi/kairos/issues"
  },
  "homepage": "https://github.com/kevinbadi/kairos#readme",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.0",
    "@creatoros/cli": "^0.1.7",
    "@inquirer/prompts": "^8.5.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
