# Kairos worker — the always-on Railway service that runs every scheduled
# automation for one workspace in a single container.
#
# Railway setup (one time):
#   1. New service from this repo; set Dockerfile path to Dockerfile.worker.
#   2. Variables: CREATOROS_API_KEY, ANTHROPIC_API_KEY (or
#      CLAUDE_CODE_OAUTH_TOKEN from `claude setup-token` to stay on a
#      Claude plan), KAIROS_WORKER_TOKEN (any long random string),
#      TZ (e.g. America/Toronto — cron hours run in this zone).
#   3. Set an Anthropic Console spend limit BEFORE first deploy.
#   4. Networking → generate a public domain; put it in kairos/kairos.json
#      as worker.url so the dashboard can poll /health and /runs.
#
# The workspace (kairos/ config, skills, automations.json) ships in the
# image — redeploy on workspace changes, or mount a volume to skip that.

FROM node:22-bookworm-slim

WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci --omit=dev && npm cache clean --force
COPY . .

ENV NODE_ENV=production
# The container runs as root, and Claude refuses unattended
# bypassPermissions as root by design (exit 1 on every scheduled run).
# IS_SANDBOX=1 tells it this is an isolated container — required.
ENV IS_SANDBOX=1
EXPOSE 8790
CMD ["npx", "tsx", "src/worker/index.ts"]
